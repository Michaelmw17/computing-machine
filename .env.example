# Copy this file to .env.local and fill in the value for local development.
# In production, set this as an environment variable in your hosting provider
# (AWS Amplify Console → App settings → Environment variables).
#
# The contact form POSTs to a Cloudflare Worker that holds the EmailJS
# secrets server-side. The Worker URL is public (it's CORS-locked to
# jdpelectrical.com.au) so this value is fine in client source.
#
# See cf-worker/README.md for how to deploy the Worker and obtain the URL.

REACT_APP_CONTACT_API_URL=https://jdp-contact-proxy.your-subdomain.workers.dev
